{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/*.d.ts"],
  "ignoreBinaries": ["bun", "docker"],
  "ignoreUnresolved": ["^bun:"],
  "workspaces": {
    "loop": {
      "entry": ["src/index.ts", "src/agents/write.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
