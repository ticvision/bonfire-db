{
  "name": "bonfire-db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=24 <25",
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:packages && bun run build:api && bun run build:demo",
    "build:api": "bun run --cwd apps/api build",
    "build:demo": "bun run --cwd apps/demo build",
    "build:packages": "bun run --cwd packages/core build && bun run --cwd packages/sdk build && bun run --cwd packages/mcp build",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:demo": "bun run --cwd apps/demo dev",
    "lint": "bun run scripts/smoke/lint.ts",
    "scan:synthetic-only": "bun run scripts/smoke/synthetic-only.ts",
    "smoke:demo": "bun run scripts/smoke/demo.ts",
    "smoke:offline": "bun run scripts/smoke/offline.ts",
    "test": "bun test apps packages",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.9.0"
  }
}
