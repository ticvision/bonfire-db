{
  "name": "bonfire-db",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "loop",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "biome check --write .",
    "test": "turbo run test",
    "gate": "turbo run gate",
    "db:migrate": "bun run packages/core/src/db/migrate.ts",
    "gen:agents": "bun run loop/src/agents/write.ts",
    "loop": "bun run loop/src/cli/bin.ts"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.0",
    "@biomejs/biome": "2.5.1",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "24.13.2",
    "@types/picomatch": "4.0.3",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-ai-guardrails": "^1.3.2",
    "jiti": "^2.7.0",
    "jscpd": "^5.0.11",
    "knip": "^6.20.0",
    "picomatch": "4.0.4",
    "smol-toml": "1.7.0",
    "turbo": "2.10.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  }
}
