# Bonfire DB — example environment (SYNTHETIC dev-only values, never real secrets).
#
# You do NOT need this file to boot: docker-compose.yml carries identical inline
# defaults, so `docker compose up -d --wait` works on a clean clone with zero
# keys. Copy to .env only if you want to override something.

# --- Postgres container (superuser owns DDL; used only by migrations) --------
POSTGRES_DB=bonfire
POSTGRES_USER=postgres
POSTGRES_PASSWORD=bonfire-dev-only-superuser-pw
# Host port Postgres is published on; change if 5432 is taken locally.
DB_HOST_PORT=5432

# --- Runtime application role (LOGIN NOSUPERUSER NOBYPASSRLS; RLS applies) ---
APP_DB_PASSWORD=bonfire-dev-only-app-pw

# --- API ----------------------------------------------------------------------
# Host port mapping for the api container (container listens on 8080).
API_PORT=8080

# --- Host-side tools (tests, local dev) ---------------------------------------
# App-role connection string; this dev default is also baked into the code.
DATABASE_URL=postgres://bonfire_app:bonfire-dev-only-app-pw@127.0.0.1:5432/bonfire
# Superuser connection used ONLY by `bun run db:migrate` (never by the app).
MIGRATE_DATABASE_URL=postgres://postgres:bonfire-dev-only-superuser-pw@127.0.0.1:5432/bonfire
